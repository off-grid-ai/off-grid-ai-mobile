require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '17.0'  # Raised to 17.0 for ml-stable-diffusion (Core ML image gen)

prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'OffgridMobile' do
  config = use_native_modules!
  
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # onnxruntime-objc ships no module map; OffgridPro (a Swift pod) imports it for
  # the auto-detect VAD, so it must be built with modular headers when pods are
  # statically linked. Without this, pod install fails to integrate the Swift pod.
  pod 'onnxruntime-objc', :modular_headers => true

  target 'OffgridMobileTests' do
    inherit! :search_paths
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # fmt 11.0.2's consteval format-string check is broken under the clang in
    # Xcode 26+, failing with "call to consteval function ... is not a constant
    # expression" when compiling fmt and the Yoga/React-* pods that include it.
    # base.h defines FMT_USE_CONSTEVAL unconditionally (no #ifndef guard), so a
    # -D define can't override it. Neutralize the detection so it falls back to
    # runtime checking, which is exactly what fmt does for older toolchains.
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      guard = '// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.'
      if contents.include?(guard) && !contents.include?('FMT_FORCE_NO_CONSTEVAL')
        contents = contents.sub(
          guard,
          "#define FMT_FORCE_NO_CONSTEVAL 1\n#define FMT_USE_CONSTEVAL 0\n#if 0  // forced off for Xcode 26+ clang\n#{guard}"
        )
        # close the `#if 0` we opened, right before FMT_CONSTEVAL is defined from it
        contents = contents.sub("#if FMT_USE_CONSTEVAL\n", "#endif  // forced FMT_USE_CONSTEVAL off\n#if FMT_USE_CONSTEVAL\n")
        File.chmod(0644, fmt_base)
        File.write(fmt_base, contents)
        Pod::UI.puts "Patched fmt base.h to disable broken consteval path".yellow
      end
    end

    # Set C++20 for all pods and deployment target
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
        if target.name == 'fmt'
          config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -Wno-error'
        end
      end
    end
  end
end