# Fastlane environment template — copy to fastlane/.env and fill in.
# fastlane/.env is gitignored; never commit real credentials.
# In CI these are provided as GitHub Actions secrets, not from this file.

# ── Android: Google Play upload (NEW — App/Play Store publishing) ───
# Play Store service-account JSON key (Supply / upload_to_play_store).
# Create at: Play Console > Setup > API access > Service accounts (grant Release perm).
PLAY_STORE_JSON_KEY_PATH=./fastlane/play-store-key.json

# ── Android: release signing (production keystore) ─────────────────
# These map to the gradle properties android/app/build.gradle reads
# (OFFGRID_UPLOAD_*). Without them, release builds fall back to the debug key.
OFFGRID_UPLOAD_STORE_FILE=./android/app/release.keystore
OFFGRID_UPLOAD_STORE_PASSWORD=
OFFGRID_UPLOAD_KEY_ALIAS=
OFFGRID_UPLOAD_KEY_PASSWORD=

# ── iOS: App Store Connect upload (NEW) ────────────────────────────
# App Store Connect API key, used to UPLOAD to TestFlight / App Store.
# Create at: App Store Connect > Users and Access > Integrations > App Store Connect API.
APP_STORE_CONNECT_API_KEY_PATH=./fastlane/asc-api-key.json

# ── iOS: signing (REUSES the repo's existing AltStore signing secrets) ──
# Same secrets release-ios.yml already uses — no fastlane match.
# Base64-encoded .p12 and .mobileprovision (same values already in GitHub Secrets).
IOS_CERTIFICATE_P12=
IOS_CERTIFICATE_PASSWORD=
IOS_PROVISION_PROFILE=
KEYCHAIN_PASSWORD=

# Apple Developer Team ID (defaults to 84V6KCAC49 from ios/ExportOptions.plist).
APPLE_TEAM_ID=84V6KCAC49

# Read by fastlane/Appfile (each optional; set if your account needs them):
#   APPLE_ID     Apple ID email for App Store Connect
#   ITC_TEAM_ID  App Store Connect team id, if you belong to more than one
#   TEAM_ID      Developer Portal team id, if you belong to more than one
APPLE_ID=
ITC_TEAM_ID=
TEAM_ID=

# On a local Mac where the distribution cert is already in your login keychain,
# set this to skip the temp-keychain import step:
# SKIP_KEYCHAIN_IMPORT=1
